{
    "name": "rezult/financeiro",
    "description": "SaaS de gestão financeira empresarial",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "phpoffice/phpspreadsheet": "^2.2",
        "mpdf/mpdf": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "config": {
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit tests/"
    }
}

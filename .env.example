APP_NAME=Rezult
APP_URL=http://localhost:8000
APP_ENV=local
APP_DEBUG=true
APP_KEY=

# demo = Pix/boleto simulados permitidos | live = exige gateway em produção
FINANCIAL_MODE=demo

# IPs do proxy reverso (nginx) separados por vírgula, ou * para confiar em X-Forwarded-Proto
# TRUSTED_PROXIES=127.0.0.1

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rezult
DB_USERNAME=root
DB_PASSWORD=

MAIL_FROM=noreply@rezult.local
MAIL_FROM_NAME=Rezult
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

LGPD_DPO_EMAIL=privacidade@rezult.app

UPLOAD_MAX_MB=5
SESSION_LIFETIME=7200
DASHBOARD_CACHE_TTL=300

# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Token opcional para proteger /health (obrigatório se APP_ENV=production)
# HEALTH_TOKEN=

# E-mail promovido automaticamente a superadmin no login
# SUPERADMIN_EMAIL=admin@rezult.app

# Criar superadmin manualmente:
# php bin/create-superadmin.php "Nome" email@exemplo.com "SenhaForte123"

APP_NAME=Rezult
APP_URL=http://localhost:8000
APP_ENV=local
APP_DEBUG=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rezult
DB_USERNAME=root
DB_PASSWORD=

MAIL_FROM=noreply@rezult.local
MAIL_FROM_NAME=Rezult
MAIL_HOST=

# Cron diário:
# php bin/cron-recorrente.php
# php bin/cron-emails.php
# php bin/cron-lgpd.php
# php bin/cron-automacao.php

# Assistente IA (opcional — sem chave usa respostas locais)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

LGPD_DPO_EMAIL=privacidade@rezult.app

UPLOAD_MAX_MB=5
SESSION_LIFETIME=7200
DASHBOARD_CACHE_TTL=300

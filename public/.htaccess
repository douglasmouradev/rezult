<IfModule mod_rewrite.c>
    RewriteEngine On

    # Favicon — mesmo caminho que /assets/img/ (funciona no aaPanel/nginx+apache)
    RewriteRule ^favicon\.ico$ assets/img/favicon.ico [L]
    RewriteRule ^favicon\.png$ assets/img/favicon.png [L]
    RewriteRule ^favicon-16x16\.png$ assets/img/favicon-16x16.png [L]
    RewriteRule ^favicon-32x32\.png$ assets/img/favicon-32x32.png [L]
    RewriteRule ^apple-touch-icon\.png$ assets/img/apple-touch-icon.png [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>
